generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Notion Service ───────────────────────────────────────────────────────────

model NotionOperation {
  id          String              @id @default(uuid())
  messageId   String              @unique
  operation   String
  body        String
  metadata    Json?
  status      NotionOpStatus      @default(PENDING)
  notionId    String?
  errorReason String?
  executedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum NotionOpStatus {
  PENDING
  SUCCESS
  FAILED
}

